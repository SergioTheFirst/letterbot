# Быстрый старт: используйте компактный шаблон
# mailbot_v26/config/config.ini.compact.example

# ===== GENERAL =====
check_interval=120                     ' Интервал опроса почтового сервера (в секундах). Чем меньше — тем чаще проверка новых писем, но выше нагрузка. Обычно 60–600 (default=120).
max_email_mb=15                       ' Максимальный размер одного письма для обработки (в мегабайтах). Письма больше этого будут пропущены, чтобы защититься от огромных писем. Обычно 5–50 (default=15).
max_attachment_mb=15                  ' Максимальный размер каждого вложения (в МБ). Ограничение на размер файлов, которые бот попытается обработать. Обычно 5–100 (default=15).
max_zip_uncompressed_mb=80            ' Ограничение на общий распакованный объём zip-архива (в МБ), чтобы защититься от zip-бомб. Обычно 50–200 (default=80).
max_extracted_chars=50000             ' Максимум символов, извлекаемых из текста сообщений/вложений для анализа. Ограничивает общий объём текста. Обычно 10000–200000 (default=50000).
max_extracted_total_chars=120000      ' Общий верхний предел символов, которые бот может обработать за один цикл. Защищает от огромных писем. Обычно 50000–300000 (default=120000).
admin_chat_id=                        ' Telegram chat ID администратора, куда бот отправляет отчёты об ошибках и важные уведомления. Пример: 123456789. Оставь пустым если не используешь.
attention_cost_per_hour=0             ' Стоимость “внимания” в час (для будущей логики экономики производительности). Если не используешь — оставь 0 (default=0).

# ===== INGEST =====
allow_prestart_emails=false           ' Захватывать ли старые письма, которые были до первого запуска бота. Если false — бот начнёт только с новых писем (true/false, default=false).

# ===== MAINTENANCE =====
maintenance_mode=0                    ' Включить режим обслуживания (1 — только сервисные задачи, 0 — обычная работа). Полезно при обновлениях/обслуживании (0/1, default=0).

# ===== STORAGE =====
db_path=mailbot.sqlite                ' Путь к базе данных SQLite. Может быть относительным (mailbot.sqlite — рядом с EXE) или абсолютным (C:/path/db.sqlite). Default=mailbot.sqlite.

# ===== LLM PROVIDERS =====
primary=gigachat                      ' Основной провайдер LLM. Например gigachat или cloudflare. Используется по умолчанию для генерации ответов/анализов (default=gigachat).
fallback=cloudflare                   ' Резервный LLM, если основной не отвечает или падает. Например cloudflare или другой установленный провайдер (default=cloudflare).

# ===== GIGACHAT =====
gigachat_enabled=true                 ' Включить/выключить интеграцию с Gigachat (true/false, default=true). Если false — Gigachat не будет использоваться даже если указан в primary.
gigachat_api_key=CHANGE_ME            ' API-ключ для доступа к Gigachat. Например “sk-abcdef123456”. Обязательно замените на свой действующий ключ.

# ===== CLOUDFLARE =====
cloudflare_enabled=true               ' Включить/выключить интеграцию с Cloudflare LLM (true/false, default=true). Если false — Cloudflare не будет использоваться как LLM.

# ===== SAFETY/TIMING =====
gigachat_max_consecutive_errors=3     ' Сколько подряд ошибок от Gigachat допускается перед паузой/откатом (целое 1–10, default=3). Это помогает избежать бесконечных падений.
gigachat_max_latency_sec=10           ' Таймаут ожидания ответа от Gigachat в секундах (5–60, default=10). Если ответ задерживается дольше — считается ошибка.
gigachat_cooldown_sec=600             ' Время отдыха/отката после серии ошибок (сек, 300–1800, default=600). Защищает от частых запросов к плохому провайдеру.

# ===== UI =====
locale=ru                             ' Язык интерфейса и сообщений (ru/en/…; default=ru). Позволяет выводить сообщения в нужной локали.

# ===== FEATURES =====
enable_auto_priority=false            ' Включить автоматическое вычисление приоритетов писем (true/false, default=false). Автоматически присваивает важность письмам.
enable_daily_digest=true              ' Включить ежедневный дайджест — краткий отчёт каждому дню (true/false, default=true).
enable_weekly_digest=false            ' Включить еженедельный дайджест (true/false, default=false).
enable_weekly_accuracy_report=false   ' Включить отчёт точности (оценка, насколько модель попадает в реальные ожидания) (true/false, default=false).
enable_weekly_calibration_report=false ' Включить отчёт калибровки (показывает доверие/неточность модели) (true/false, default=false).
enable_digest_insights=false          ' Включить генерацию кратких инсайтов по письмам (true/false, default=false).
enable_digest_action_templates=false  ' Включить шаблоны действий/ответов (true/false, default=false).
enable_anomaly_alerts=false           ' Включать оповещения об аномалиях в почте (true/false, default=false).
enable_quality_metrics=false          ' Включить расчёт метрик качества (true/false, default=false).
enable_hierarchical_mail_types=false  ' Включить иерархическую классификацию типов писем (true/false, default=false).
enable_priority_v2=true               ' Включить вторую версию алгоритма приоритетов (true/false, default=true).
enable_narrative_binding=true         ' Включить связывание писем в историю (true/false, default=true).
enable_narrative_patterns=true        ' Включить распознавание паттернов в письмах (true/false, default=true).
enable_circadian_delivery=true        ' Управление доставкой по биоритмам/часам (true/false, default=true).
enable_flow_protection=false          ' Включить защиту фокуса от прерываний (true/false, default=false).
enable_attention_debt=true            ' Учитывать “долг внимания” (приоритет непрочитанных важных писем) (true/false, default=true).
enable_surprise_budget=true           ' Включить бюджет “сюрпризов” (ограничивает неожиданные события) (true/false, default=true).
enable_silence_as_signal=shadow       ' Использовать тишину как сигнал (true/false/shadow, default=shadow). Shadow = фиксирует без влияния.
enable_deadlock_detection=shadow      ' Включить детектор дедлоков (true/false/shadow, default=shadow). Shadow = анализ без вмешательства.
enable_premium_processor=false        ' Включить премиум-процессор (платное/расширенное поведение) (true/false, default=false).
enable_premium_clarity_v1=false       ' Включить премиум-ясность версии 1 (true/false, default=false).
enable_behavior_metrics_digest=false  ' Включить отчёт поведенческих метрик (true/false, default=false).
enable_trust_bootstrap=false          ' Включить начальное обучение доверия (true/false, default=false).
enable_regret_minimization=false      ' Включить стратегию минимизации сожаления (true/false, default=false).
enable_uncertainty_queue=false        ' Включить очередь неопределённости (true/false, default=false).
enable_commitment_chain_digest=false  ' Включить дайджест цепочек обязательств (true/false, default=false).

# ===== PRIORITY V2 =====
urgency_weight_default=12             ' Базовый вес срочности для алгоритма приоритетов (целое 5–30, default=12).
urgency_weight_by_type=30             ' Вес срочности в зависимости от типа письма (целое 10–50, default=30).
amount_base_points=5                  ' Баллы за сумму (вес для суммы в письме) (целое 0–20, default=5).
amount_10k_points=10                  ' Баллы если сумма ≥ 10k (целое 0–50, default=10).
amount_50k_points=20                  ' Баллы если сумма ≥ 50k (целое 0–50, default=20).
amount_100k_points=30                 ' Баллы если сумма ≥ 100k (целое 0–50, default=30).
deadline_1d_points=30                 ' Баллы если дедлайн через 1 день (целое 0–50, default=30).
deadline_3d_points=20                 ' Баллы если дедлайн через 3 дня (целое 0–40, default=20).
deadline_7d_points=10                 ' Баллы если дедлайн через 7 дней (целое 0–30, default=10).
type_invoice_final_points=25          ' Баллы за письмо типа “инвойс” (целое 0–50, default=25).
type_reminder_escalation_points=22    ' Баллы за письмо типа “эскалация” (целое 0–50, default=22).
type_contract_termination_points=20   ' Баллы за письмо типа “расторжение” (целое 0–50, default=20).
type_claim_points=20                  ' Баллы за письмо типа “претензия” (целое 0–50, default=20).
vip_base_score=20                     ' Базовый VIP-балл (целое 0–50, default=20).
vip_multiplier_fyi=0.3                ' Множитель VIP FYI (float 0.0–1.0, default=0.3).
vip_multiplier_freq=0.5               ' Множитель VIP частоты (float 0.0–2.0, default=0.5).
vip_multiplier_commitment=1.5         ' Множитель VIP участия (float 0.0–5.0, default=1.5).
vip_multiplier_min=0.2                ' Минимальный VIP множитель (float 0.0–1.0, default=0.2).
vip_multiplier_max=2.0                ' Максимальный VIP множитель (float 1.0–5.0, default=2.0).
freq_spike_threshold=3.0              ' Порог частотного всплеска (float 1.0–5.0, default=3.0).
freq_spike_points=15                  ' Баллы за частотный всплеск (целое 0–50, default=15).
chain_two_points=10                   ' Баллы за цепочку из 2 (целое 0–30, default=10).
chain_three_points=25                 ' Баллы за цепочку из 3 (целое 0–40, default=25).
priority_red_threshold=70             ' Порог для “красного” уровня (целое 50–90, default=70).
priority_yellow_threshold=35          ' Порог для “жёлтого” уровня (целое 20–60, default=35).

[donate]
enabled = 0
url = https://...
text = Поддержать проект
[features]
donate_enabled = false
support = false
