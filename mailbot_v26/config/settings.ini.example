[general]
check_interval = 120  ; seconds between IMAP polling cycles
max_email_mb = 15
max_attachment_mb = 15
admin_chat_id =

[storage]
db_path = data/mailbot.sqlite

[features]
enable_premium_processor = true  ; premium TG renderer + inline buttons by default
enable_daily_digest = true
enable_weekly_digest = false

[web]
host = 127.0.0.1  ; Web UI bind host
port = 8787       ; Web UI bind port
